# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
# ----------------------------------------------------------------------
# IMPORTANT FOR CONTRIBUTORS:
# To connect to the shared development database, please request the
# MONGODB_URI credentials from the project maintainer via the Git issue,
# OR set up your own local MongoDB instance for testing.
# ----------------------------------------------------------------------

# Example Local URI:
# MONGODB_URI=mongodb://localhost:27017/stellarproof

# Example Cloud URI (MongoDB Atlas):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/stellarproof?retryWrites=true&w=majority

# Storage Provider Configuration
# ----------------------------------------------------------------------
# Cloudinary - Image hosting and optimization
# Sign up at https://cloudinary.com/ and get credentials from your dashboard
# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Cloudinary Configuration (SPV encrypted asset storage)
# ----------------------------------------------------------------------
# IMPORTANT FOR CONTRIBUTORS:
# Request Cloudinary credentials from the project maintainer, or create
# a free account at https://cloudinary.com and use your own cloud.
# ----------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# IPFS - Decentralized storage
# Use either a local IPFS node or a public API
# Local: http://localhost:5001
# Infura: https://ipfs.infura.io:5001
# Web3.Storage: https://api.web3.storage (requires API key)
IPFS_API_URL=http://localhost:5001
IPFS_API_KEY=
# Optional: Custom IPFS gateway URL (defaults to dweb.link)
# IPFS_GATEWAY_URL=https://your-gateway.example.com
# KMS Configuration
# ----------------------------------------------------------------------
# Master key used to encrypt/decrypt KMS keys in the database
# IMPORTANT: Must be exactly 64 hex characters (32 bytes for AES-256)
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------------------
KMS_MASTER_KEY=your_64_char_hex_master_key_here

# IPFS / Pinata Configuration
# ----------------------------------------------------------------------
# Generate a JWT at https://app.pinata.cloud/keys (API v3, scoped to
# pinFileToIPFS and pinJSONToIPFS). The gateway URL is your Pinata
# dedicated gateway or the public gateway (no auth required).
# ----------------------------------------------------------------------
PINATA_JWT=your_pinata_jwt_here
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
