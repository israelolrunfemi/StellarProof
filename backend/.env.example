# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
# ----------------------------------------------------------------------
# IMPORTANT FOR CONTRIBUTORS: 
# To connect to the shared development database, please request the 
# MONGODB_URI credentials from the project maintainer via the Git issue, 
# OR set up your own local MongoDB instance for testing.
# ----------------------------------------------------------------------

# Example Local URI:
# MONGODB_URI=mongodb://localhost:27017/stellarproof

# Example Cloud URI (MongoDB Atlas):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/stellarproof?retryWrites=true&w=majority

# Storage Provider Configuration
# ----------------------------------------------------------------------
# Cloudinary - Image hosting and optimization
# Sign up at https://cloudinary.com/ and get credentials from your dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# IPFS - Decentralized storage
# Use either a local IPFS node or a public API
# Local: http://localhost:5001
# Infura: https://ipfs.infura.io:5001
# Web3.Storage: https://api.web3.storage (requires API key)
IPFS_API_URL=http://localhost:5001
IPFS_API_KEY=
# Optional: Custom IPFS gateway URL (defaults to dweb.link)
# IPFS_GATEWAY_URL=https://your-gateway.example.com
